# ===== 字体 =====
font-family = Hack Nerd Font
font-size = 13

# ===== 外观 =====
theme = Catppuccin Frappe
background-opacity = 0.85
window-padding-x = 8
window-padding-y = 8

# ===== 光标 =====
cursor-style = block
cursor-style-blink = false
cursor-opacity = 0.85

# ===== Shell 集成 =====
shell-integration-features = no-cursor
